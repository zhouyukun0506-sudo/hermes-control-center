{
  "name": "workbench",
  "description": "Professional productivity workspace with Hermes Agent. macOS 26 Liquid Glass design.",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "electron": "electron electron.cjs",
    "dist:win": "npm run build && electron-builder --win --x64 --arm64 && cd release && zip -r ../release-win.zip win-*",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist": "npm run build && electron-builder --win --mac"
  },
  "build": {
    "appId": "com.hermes.workbench",
    "productName": "Workbench",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron.cjs",
      "server/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "asar": true
  },
  "dependencies": {
    "concurrently": "^9.1.0",
    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "vite": "^6.0.0"
  }
}
